extends layout

block content
  h1= title
  
  div.container-fluid
    form(method='POST' action=`/books/update`)
      input(type='hidden' name='id' value=book._id)
      
      div.form-group
        label(for='title') Title:
        input#title.form-control(type='text' name='title' value=book.title required)
      
      div.form-group
        label(for='author') Author:
        input#author.form-control(type='text' name='author' value=book.author required)
      
      div.form-group
        label(for='isbn') ISBN:
        input#isbn.form-control(type='text' name='isbn' value=book.isbn required)
      
      div.form-group
        label(for='pages') Pages:
        input#pages.form-control(type='number' name='pages' value=book.pages required)
      
      div.form-group
        label(for='price') Price:
        input#price.form-control(type='number' step='0.01' name='price' value=book.price required)
      
      div.form-group
        label(for='genre') Genre:
        input#genre.form-control(type='text' name='genre' value=book.genre required)
      
      div.mt-3
        button.btn.btn-primary.mr-2(type='submit') Update
        button.btn.btn-secondary(type='button' onclick="window.location.href='/books'") Cancel
